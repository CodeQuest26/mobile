{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "constants/colors.ts",
    "app/(screens)/(manufacturer)/(screens)/profile.tsx",
    "app/(screens)/(manufacturer)/(tabs)/bids.stsx",
    "app/(screens)/(manufacturer)/(screens)/ChatRoom.ttsx"
  ]
}
